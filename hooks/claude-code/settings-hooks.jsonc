// UI Mock Hook 配置（Claude Code）
// 将此内容合并到项目 .claude/settings.local.json 的 "hooks" 字段中
{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Create|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/ui-mock-one-page.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Create|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/ui-mock-principles-check.sh"
          }
        ]
      }
    ]
  }
}
